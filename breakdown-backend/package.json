{
  "name": "breakdown-backend",
  "version": "1.0.0",
  "description": "Backend API for Breakdown App - Furniture Manufacturing System",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "migrate:rollback": "node src/db/migrate.js rollback",
    "migrate:stock": "node scripts/migrate_stock.js",
    "migrate:stock:dedup": "node scripts/dedup_stock.js",
    "migrate:template": "node scripts/migrate_excel_template.js",
    "migrate:bom-setting": "node scripts/migrate_bom_setting.js",
    "setup": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
